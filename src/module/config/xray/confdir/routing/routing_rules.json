[
    {
        "name": "DNS 劫持",
        "type": "field",
        "inboundTag": [
            "tproxy-in"
        ],
        "port": "53",
        "outboundTag": "dns-out",
        "enabled": true,
        "visible": false
    },
    {
        "name": "API 转发",
        "type": "field",
        "inboundTag": [
            "api"
        ],
        "outboundTag": "api",
        "enabled": true,
        "visible": false
    },
    {
        "name": "Прямое соединение (RU IP & Private)",
        "type": "field",
        "ip": [
            "geoip:private",
            "geoip:ru"
        ],
        "outboundTag": "direct",
        "enabled": true,
        "visible": true
    },
    {
        "name": "Прямое соединение (RU Domains & Apple)",
        "type": "field",
        "domain": [
            "geosite:category-ru",
            "geosite:private",
            "geosite:apple",
            "regexp:.*\\.ru$",
            "regexp:.*\\.su$",
            "regexp:.*\\.xn--p1ai$",
            "domain:avito.st",
            "domain:edu22.info" 
        ],
        "outboundTag": "direct",
        "enabled": true,
        "visible": true
    },
    {
        "name": "Весь остальной трафик через Прокси",
        "type": "field",
        "port": "0-65535",
        "network": "tcp,udp",
        "outboundTag": "proxy",
        "enabled": true,
        "visible": true
    }
]
